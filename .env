# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your application (client) ID, found on the same page as the token
CLIENT_ID=your_application_id_here

# Optional: a single guild ID for instant command deployment while testing.
# Leave blank to deploy commands globally (takes up to 1 hour to propagate).
GUILD_ID=your_test_server_id_here
